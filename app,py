# Helper functions
@st.cache_data
def load_data(file):
    df = pd.read_csv(file)
    return df

def preprocess_data(df):
    df_processed = df.copy()
    
    # Drop CustomerID as it's not a predictive feature
    if 'CustomerID' in df_processed.columns:
        df_processed.drop('CustomerID', axis=1, inplace=True)
        
    # Handle specific types like TotalCharges which often have space instead of NaN
    if 'TotalCharges' in df_processed.columns:
        if df_processed['TotalCharges'].dtype == 'object':
            df_processed['TotalCharges'] = pd.to_numeric(df_processed['TotalCharges'].replace(r'^\s*$', np.nan, regex=True))
        df_processed['TotalCharges'] = df_processed['TotalCharges'].fillna(df_processed['TotalCharges'].median())
        
    # Fill any other numeric missing
    numeric_cols = df_processed.select_dtypes(include=['number']).columns
    for col in numeric_cols:
        df_processed[col] = df_processed[col].fillna(df_processed[col].median())
        
    # Fill categorical missing
    cat_cols = df_processed.select_dtypes(include=['object']).columns
    for col in cat_cols:
        df_processed[col] = df_processed[col].fillna(df_processed[col].mode()[0])
        
    # Categorical encoding
    le = LabelEncoder()
    label_encoders = {}
    for col in cat_cols:
        df_processed[col] = le.fit_transform(df_processed[col].astype(str))
        label_encoders[col] = le
        
    return df_processed, label_encoders

def train_models(df_processed):
    if 'Churn' not in df_processed.columns:
        raise ValueError("Dataset does not contain a 'Churn' column.")
        
    X = df_processed.drop('Churn', axis=1)
    y = df_processed['Churn']
    
    # Ensure all data is numeric
    X = X.apply(pd.to_numeric, errors='coerce').fillna(0)
    
    # Scale features
    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)
    
    X_train, X_test, y_train, y_test = train_test_split(X_scaled, y, test_size=0.2, random_state=42)
    
    models = {
        'Logistic Regression': LogisticRegression(random_state=42),
        'Decision Tree': DecisionTreeClassifier(random_state=42, max_depth=5),
        'Random Forest': RandomForestClassifier(random_state=42, n_estimators=100)
    }
    
    results = {}
    trained_models = {}
    
    for name, model in models.items():
        model.fit(X_train, y_train)
        y_pred = model.predict(X_test)
        acc = accuracy_score(y_test, y_pred)
        cm = confusion_matrix(y_test, y_pred)
        
        # Feature importance
        if name in ['Decision Tree', 'Random Forest']:
            importance = model.feature_importances_
        else:
            importance = np.abs(model.coef_[0])
            
        feat_imp = pd.DataFrame({
            'Feature': X.columns,
            'Importance': importance
        }).sort_values(by='Importance', ascending=False)
        
        results[name] = {
            'Accuracy': acc,
            'Confusion Matrix': cm,
            'Feature Importance': feat_imp
        }
        trained_models[name] = model
        
    return trained_models, results, scaler, X.columns

