import pandas as pd
import numpy as np

def generate_data(num_samples=1000):
    np.random.seed(42)
    
    # Generate columns
    customer_ids = [f"CUST{str(i).zfill(4)}" for i in range(1, num_samples + 1)]
    genders = np.random.choice(['Male', 'Female'], size=num_samples)
    tenures = np.random.randint(1, 73, size=num_samples) # 1 to 72 months
    monthly_charges = np.random.uniform(20.0, 120.0, size=num_samples).round(2)
    total_charges = (tenures * monthly_charges * np.random.uniform(0.9, 1.1, size=num_samples)).round(2)
    contracts = np.random.choice(['Month-to-month', 'One year', 'Two year'], size=num_samples, p=[0.5, 0.3, 0.2])
    internet_service = np.random.choice(['DSL', 'Fiber optic', 'No'], size=num_samples, p=[0.3, 0.5, 0.2])
    
    # Generate synthetic Churn with some logic to make the model perform reasonably
    # Higher churn if: month-to-month, fiber optic (expensive?), short tenure, high monthly charges
    churn_prob = np.zeros(num_samples)
    
    churn_prob += np.where(contracts == 'Month-to-month', 0.3, 0.0)
    churn_prob -= np.where(contracts == 'Two year', 0.2, 0.0)
    churn_prob += np.where(tenures < 12, 0.2, 0.0)
    churn_prob -= np.where(tenures > 48, 0.2, 0.0)
    churn_prob += np.where(monthly_charges > 80, 0.1, 0.0)
    
    # Add random noise
    churn_prob += np.random.normal(0, 0.1, num_samples)
    
    # Convert to binary
    churn_prob = np.clip(churn_prob, 0.0, 1.0)
    churns = np.random.binomial(1, churn_prob)
    churn_labels = np.where(churns == 1, 'Yes', 'No')
    
    df = pd.DataFrame({
        'CustomerID': customer_ids,
        'Gender': genders,
        'Tenure': tenures,
        'MonthlyCharges': monthly_charges,
        'TotalCharges': total_charges,
        'Contract': contracts,
        'InternetService': internet_service,
        'Churn': churn_labels
    })
    
    # Inject some missing values for 'TotalCharges' to test preprocessing
    missing_indices = np.random.choice(df.index, size=15, replace=False)
    df.loc[missing_indices, 'TotalCharges'] = np.nan
    
    # Save to CSV
    df.to_csv('telecom_churn_sample.csv', index=False)
    print(f"Sample data generated with {num_samples} records and saved to 'telecom_churn_sample.csv'.")

if __name__ == "__main__":
    generate_data()
